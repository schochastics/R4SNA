fit(forested ~ ., data = forested_train)
tree_spec <- decision_tree(cost_complexity = 0.001, min_n = 300) %>%
set_mode("classification") %>%
set_engine("rpart")
tree_fit <- tree_spec %>%
fit(forested ~ ., data = forested_train)
# Extract the fitted rpart object from the parsnip fit
library(rpart.plot)
rpart.plot::rpart.plot(tree_fit$fit,roundint=FALSE)
rpart.plot::rpart.plot(tree_fit$fit,roundint=FALSE)
