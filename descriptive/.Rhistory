library(ggforce)
p <- assoc_graph(dyad_var, 0.10)
# nodes to highlight
highlight_nodes <- subset(p$data, name %in% c("friend", "cowork", "advice"))
# circle center
cx <- mean(highlight_nodes$x)
cy <- mean(highlight_nodes$y)
# radius with a little padding
r <- max(sqrt((highlight_nodes$x - cx)^2 + (highlight_nodes$y - cy)^2)) + 0.05
p +
ggforce::geom_circle(
data = data.frame(x0 = cx, y0 = cy, r = r),
aes(x0 = x0, y0 = y0, r = r),
color = "red",
linewidth = 1.2,
inherit.aes = FALSE
)
